# Environment Configuration: Production
NODE_ENV=production
PORT=5000

# Database (PostgreSQL Production Instance)
# Replace with highly available database instance (e.g. AWS RDS or GCP Cloud SQL)
DATABASE_URL="postgresql://hawkedge_prod_admin:insert_extremely_secure_production_password@postgres-prod.hawkedge.internal:5432/hawkedge_production?schema=public&sslmode=require"

# Cache (Redis High Availability Production Instance)
REDIS_URL="rediss://default:insert_secure_production_redis_auth@redis-prod.hawkedge.internal:6379"

# Cryptography / Security (MUST BE SET TO HIGH ENTROPY CRYPTOGRAPHICALLY SECURE KEYS)
# Run `openssl rand -base64 32` to generate secure secrets
JWT_ACCESS_SECRET="insert_32_character_high_entropy_cryptographic_key_access"
JWT_REFRESH_SECRET="insert_32_character_high_entropy_cryptographic_key_refresh"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# OAuth (Google / GitHub Credentials for Production environment)
GOOGLE_CLIENT_ID="google_client_id_production_value"
GOOGLE_CLIENT_SECRET="google_client_secret_production_value"
GOOGLE_CALLBACK_URL="https://api.hawkedge.tech/api/auth/google/callback"

GITHUB_CLIENT_ID="github_client_id_production_value"
GITHUB_CLIENT_SECRET="github_client_secret_production_value"
GITHUB_CALLBACK_URL="https://api.hawkedge.tech/api/auth/github/callback"

# Email Services (Production transactional mail gateway SMTP)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="insert_production_smtp_password"
SMTP_FROM="noreply@hawkedge.tech"

# CORS Allowed Origins
ALLOWED_ORIGINS="https://hawkedge.tech,https://studio.hawkedge.tech,https://admin.hawkedge.tech"

# API Base Gateway (Internal Next.js server routing)
API_BASE_URL="https://api.hawkedge.tech/api"
