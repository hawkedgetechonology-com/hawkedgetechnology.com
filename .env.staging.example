# Environment Configuration: Staging
NODE_ENV=staging
PORT=5000

# Database (PostgreSQL Staging Instance)
# Replace credentials and endpoint with staging database values
DATABASE_URL="postgresql://hawkedge_staging_user:secure_staging_password@postgres-staging.hawkedge.internal:5432/hawkedge_staging?schema=public"

# Cache (Redis Staging Instance)
REDIS_URL="redis://redis-staging.hawkedge.internal:6379"

# Cryptography / Security (Replace with unique 32-character secrets in Staging)
JWT_ACCESS_SECRET="generate_a_random_32_character_string_for_staging_access"
JWT_REFRESH_SECRET="generate_a_random_32_character_string_for_staging_refresh"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# OAuth (Google / GitHub Credentials for Staging environment)
GOOGLE_CLIENT_ID="google_client_id_staging_value"
GOOGLE_CLIENT_SECRET="google_client_secret_staging_value"
GOOGLE_CALLBACK_URL="https://api.staging.hawkedge.tech/api/auth/google/callback"

GITHUB_CLIENT_ID="github_client_id_staging_value"
GITHUB_CLIENT_SECRET="github_client_secret_staging_value"
GITHUB_CALLBACK_URL="https://api.staging.hawkedge.tech/api/auth/github/callback"

# Email Services (Staging SMTP configuration)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_user_staging"
SMTP_PASS="smtp_pass_staging"
SMTP_FROM="noreply@staging.hawkedge.tech"

# CORS / CORS Access Control Allowed Origins
ALLOWED_ORIGINS="https://staging.hawkedge.tech,https://studio.staging.hawkedge.tech,https://admin.staging.hawkedge.tech"

# API Base Gateway (Internal Next.js server routing)
API_BASE_URL="https://api.staging.hawkedge.tech/api"
