# Environment: Template
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hawkedge_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Cryptography / Security
JWT_ACCESS_SECRET="hawkedge_access_secret_key_development_only_change_in_production"
JWT_REFRESH_SECRET="hawkedge_refresh_secret_key_development_only_change_in_production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# OAuth (Google / GitHub)
GOOGLE_CLIENT_ID="google_client_id_placeholder"
GOOGLE_CLIENT_SECRET="google_client_secret_placeholder"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

GITHUB_CLIENT_ID="github_client_id_placeholder"
GITHUB_CLIENT_SECRET="github_client_secret_placeholder"
GITHUB_CALLBACK_URL="http://localhost:5000/api/auth/github/callback"

# Email Services
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_user_placeholder"
SMTP_PASS="smtp_pass_placeholder"
SMTP_FROM="noreply@hawkedge.tech"

# CORS Allowed Origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# API Base Gateway (Internal Next.js server routing)
API_BASE_URL="http://localhost:5000/api"
